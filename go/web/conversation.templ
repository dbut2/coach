package web

templ Conversation(coachName string, messages []Message, pending int, debug bool) {
	@Base(coachName) {
		@conversationBar(coachName, debug)
		@PendingBanner(pending)
		<main id="chat" class="flex-1 space-y-1 overflow-y-auto px-3 py-4">
			<div class="my-2 flex justify-center">
				<span class="rounded-full bg-base-200 px-3 py-1 text-xs text-base-content/60">Today</span>
			</div>
			for _, m := range messages {
				if m.Role == RoleTool {
					@toolTrace(m)
				} else {
					@bubble(m)
				}
			}
		</main>
		<footer class="border-t border-base-200 bg-base-100 px-3 py-3 pb-[max(0.75rem,env(safe-area-inset-bottom))]">
			<form method="post" action="/conversation" class="flex items-end gap-2">
				<textarea
					name="message"
					rows="1"
					placeholder={ "Message " + coachName }
					class="textarea textarea-bordered max-h-32 min-h-12 flex-1 resize-none rounded-2xl"
				></textarea>
				<button type="submit" class="btn btn-circle btn-primary" aria-label="Send">
					<i data-lucide="arrow-up" class="size-5"></i>
				</button>
			</form>
		</footer>
		<script>
			(() => {
				const chat = document.getElementById("chat")
				if (chat) chat.scrollTop = chat.scrollHeight
			})()
		</script>
	}
}

templ conversationBar(coachName string, debug bool) {
	<header class="navbar min-h-14 border-b border-base-200 bg-base-100/90 px-3 backdrop-blur">
		<div class="flex flex-1 items-center gap-2">
			<div class="leading-tight">
				<div class="text-sm font-semibold">{ coachName }</div>
			</div>
		</div>
		<a
			href={ templ.SafeURL(debugToggleHref(debug)) }
			class={ "btn btn-ghost btn-circle btn-sm", templ.KV("text-warning", debug) }
			aria-label="Toggle debug"
			aria-pressed={ boolAttr(debug) }
		>
			<i data-lucide="bug" class="size-5"></i>
		</a>
		<a href="/settings" class="btn btn-ghost btn-circle btn-sm" aria-label="Settings">
			<i data-lucide="settings" class="size-5"></i>
		</a>
	</header>
}

func debugToggleHref(debug bool) string {
	if debug {
		return "/conversation?debug=0"
	}
	return "/conversation?debug=1"
}

func boolAttr(b bool) string {
	if b {
		return "true"
	}
	return "false"
}

templ toolTrace(m Message) {
	<div class="my-1 flex justify-center">
		<div class="flex max-w-[90%] items-center gap-1.5 rounded-lg border border-warning/30 bg-warning/5 px-2.5 py-1 font-mono text-xs text-base-content/50">
			<i data-lucide="wrench" class="size-3 shrink-0 text-warning/70"></i>
			<span class="font-semibold text-base-content/70">{ m.Tool }</span>
			if m.Content != "" {
				<span class="truncate">{ m.Content }</span>
			}
		</div>
	</div>
}

templ bubble(m Message) {
	if m.Role == RoleAssistant {
		<div class="chat chat-start">
			<div class="avatar placeholder chat-image">
				<div class="grid size-8 place-items-center rounded-full bg-primary text-primary-content">
					<i data-lucide="activity" class="size-4"></i>
				</div>
			</div>
			<div class="chat-bubble bg-base-200 text-base-content">{ m.Content }</div>
			<div class="chat-footer mt-1 text-xs text-base-content/40">{ m.Time }</div>
		</div>
	} else {
		<div class="chat chat-end">
			<div class="chat-bubble chat-bubble-primary">{ m.Content }</div>
			<div class="chat-footer mt-1 text-xs text-base-content/40">{ m.Time }</div>
		</div>
	}
}
